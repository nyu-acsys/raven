module IntList = Library.ListM[Library.IntType]

proc p0() 
  returns (ret: Int)
  requires -*-(0.5)
  ensures ret == 0
{
  var z: Int := EC.rand(2; ECVal: !=1);
  return z;
}

proc p1()
  returns (ret: Int)
  requires -*-(0.25)
  ensures ret != 0
{
  var n := EC.rand(4; ECFn: -*-(0.25), i ==> (i == 0 ? 1.0 : 0.0));
  
  if (n==0) {
    EC.contra();
  }
  return n;
}

proc p2() 
    returns (ret: Bool)
    requires -*-(0.25)
    ensures ret == true
{
    var n: Int := EC.rand(4; ECFn: -*-(0.25), i ==> (i <= 1 ? 0.0 : 0.5));

    if (n <= 1) { return true; }
    else {
        var k: Int := EC.rand(2; 
          ECFn: -*-(0.5), i ==> (i+n <= 2 ? 0 : (i+n == 3 ? 1.0 : 0)));

        if (n + k <= 2) { return true; }
        
        else if (n + k <= 3) { EC.contra(); return false; }
        else {
            while (true) { }
            assert false;
        }
    }
}

proc p3(n: Int) returns (ret: Bool)
  requires -*-(1.0/n)
  ensures ret == true
{
  var q1: Int := EC.rand(n);
  var q2: Int := EC.rand(n; ECVal: !=q1);

  if (q1 == q2) { assert false; return false; }
  else return true;
}

proc p3'(n: Int) returns (ret: Bool)
  requires 15 < n <= 18
  requires -*-(1.0/n)
  requires -*-(0.25)
  ensures ret == true
{
  var n0 := EC.rand(4; ECFn: -*-(0.25), i ==> (i == 0 ? 1.0 : 0.0));
  var q1: Int := EC.rand(n);
  var q2: Int := EC.rand(n; ECFn: -*-(1.0/n), x ==> (x == q1 ? 1.0 : 0.0));

  if (q1 == q2) { EC.contra(); assert false; return false; }
  else return true;
}

proc toy() returns (ret: Bool)
  requires -*-(0.1)
  ensures ret == true
{
  var q1: Int := EC.rand(10);
  var q2: Int := EC.rand(10; ECFn: -*-(0.1), x ==> (x == q1 ? 1.0 : 0.0));

  if (q1 == q2) { EC.contra(); return false; }
  
  return true;
}

proc p4()
{
  inhale -*-(0.4);
  var n := IntList.cons(1, IntList.cons(2, IntList.nil));
  var k := EC.rand(5; ECList: !in n);
  assert k != 1;
}

proc p5() {
  inhale -*-(0.4);

  var k2 := EC.rand(5; ECList: !in (1 :: List.cons(5, List.nil)));
}