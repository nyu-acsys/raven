import Library.Excl
import Library.Auth
import Library.ResourceAlgebra
// This file describes the following program:
// A user calls the procedure "coinflip" with a pointer "r" and a value carrying the state
// r.value: Int, r.flag: Bool, r.value_read: Bool, and r.value_published: Once,
// where *r.flag == false, and *r.value_read == false, and where there exists some value w: Int,
// *r.value == w.
// Pictorally:
// coinflip(r) is called with
// ===================================~~~~~~~~~~~~~~~~~~~|
// | r.value | r.flag | r.value_read | r.value_published |
// |=========+========+==============+~~~~~~~~~~~~~~~~~~~|
// |    w    |  false |        false |   auth(published, |
// |         |        |              |        published) |
// |==================================~~~~~~~~~~~~~~~~~~~|
// This procedure "coinflip" will appear as an atomic operation wherein a non atomic
// "coinflip_inner" is called, which spawns two distinct threads.
// This will be accomplished by the following instructions:
// In coinflip:
// - Call coinflip_inner using an atomic token
// In coinflip_inner:
// - spawn helper thread with the distinct identity "true"
// - call helper thread with the distinct identity "false"
// The threads race to swap the value of r.flag to true, and the
// thread that wins then sets r.value to w^2 + 1 or -(w^2) - 1.
// Each thread executes the following set of instructions:
// - Read r.value into v
// - Set r.value_read to true
// - Race to set r.flag to true:
//   - In the case that the thread won, set r.value to (v^2 + 1) or to (-v^2 - 1) depending on the thread identity
//   - Otherwise, do nothing.
// Meanwhile, an interferer thread runs,
// which, while r.value_read being set to true, and r.flag still being false,
// attempts to set r.value to 1:
// - while true:
//   - read r.value into the variable "n"
//   - read r.value_read into flag_value_read
//   - Conditionally perform a restricted double-compare single swap:
//     - When r.value_read is true,
//       rdcss(r.flag, r.value, false, n, 1)
//       (that is, if r.value is still w and r.flag is still false, set _just_ r.value to 1)
//
// Because of the interferer thread, it can be the case that between the original read of r.value into v, and the final write,
// r.value is set to a temporary "spoiler" value, which is not (w^2) + 1 nor -(w^2) - 1.
//
// In order to proof that this works, the following technique will be used:
// The protocol will be described as an invariant, which allows four basic
// configurations of the state:
// Pending (1), Accepted (2), Done (3), and Gone (4).
// The Pending state is the initial state of the protocol.
// In Accepted, a winning thread has been predicted, and the atomic token has been deposited,
// allowing it to be retrieved later to linearize to (w^2) + 1 or -(w^2) - 1.
// Done comprises three disjoint states:
// done-original,
// done-interferred, and
// done-set
// In all three of these, the token is already committed, and "published" is set;
// the three merely differ on where they are after the commit: done-interfered happens
// when the interferer thread sets to a spoiler value,
// and finally done-set happens when one of the helper threads finally sets r.value to
// w^2 + 1 or -(w^2) - 1.
// Finally, in (4) Gone, the token has been removed from the invariant.
// The structure is otherwise similar to RDCSS, with "excl" tokens used to enforce
// a linear progression of the protocol.
//
// The state of the program itself will also be described as an invariant, containing the invariant
// of the protocol, as well as ownership of the actual state itself.
// XX Todo: does this even make sense? It might be the case that we don't need this, because unlike
//          in the case of rdcss, there is no "quiescent" state.
//
// Then, the instructions will be interleaved with ghost code:
// > Allocate prophecy
// > Fold prophecy, token into invariant, using excl. tokens
//   to ensure that the state UNFOLDS as pending and FOLDS
//   as accepted
// - Call coinflip_inner using an atomic token
// > Unfold invariant, using "published" from invariant
//
// In coinflip_inner:
// - spawn helper thread with the distinct identity "true"
// - spawn helper thread with the distinct identity "false"
//
// In helper thread:
// > Unfold invariant to get read permissions, using excl.
//   tokens to ensure state is accepted
// - Read r.value into v
// > Use the prophesied winner to determine whether this is
//   the winning thread. If it is, then commit the token
//   and fold the invariant at done-orignal.
//   If it is not the winning thread, remain in accepted.
// > Unfold the invariant, using excl. tokens to ensure
//   that the invariant is at least in accepted
// - Set r.value_read to true
// > fold the invariant, in the case of the winning thread
//   (using excl tokens to exclude pending + accepted +
//    future states),
//   as done-interfered, and in the case
//   of the losing thread as whatever it was before
// - Race to set r.flag to true:
//     > in the case of the winning thread,
//       unfold and use excl tokens to unfold at exactly
//       done-interfered
//     > in the case of the losing thread, use the fact
//       that the flag is already at set to ensure that
//       we are past accepted.
//   - In the case that the thread won, set r.value to (v^2 + 1) or to (-v^2 - 1) depending on the thread identity
//     > winner: fold at done-set
//     > loser: nothing
//   - Otherwise, do nothing.
//     > in the case of the losing thread, use the fact
//       that the flag is already at set to ensure that
//       we are past accepted.
//     > in the case of the winning thread, use the fact
//       that done-interfered still has flag as false
//       to prove a contradiction.
// The excl. tokens will be set up in the following way:
// they will be Excl[Bool], and each helper thread
// receives, as input, one excl token for each state of done, and for gone.
// The coinflip procedure itself receives an Excl[Unit] token for pending
//  ensuring the state is accepted, and the coinflip_inner procedure
// likewise receives an Excl[Unit] token for Pending, which is taken from
// the original pending state, and ensures that the current state is exactly
// accepted.
// In this way, the excl. tokens essentially ensure that the state of the
// protocol matches exactly the place within the control flow.
// NOTE: remove the dependence on squaring,
//       to ease stress on the SMT algorithm.
// Next step: step through this and make sure that it works exactly as spec'd.
//
// Works exactly as spec'd:
module Unit: ResourceAlgebra {
  rep type T = data { case unit }
  val id: T = unit;
  func comp(x: T, y: T) returns (res: T) { unit }
  func frame(x: T, y: T) returns (res: T) { unit }
  func valid(x: T) returns (res: Bool) { true }
  func fpuAllowed(x: T, y: T) returns (res: Bool) { true }
}

module Published: ResourceAlgebra {
  rep type T = data {
    case unpublished;
    case published;
    case top
  }

  val id: T := unpublished;

  func comp(x: T, y: T) returns (res: T) {
    (x == unpublished) ? y : (
    (y == unpublished) ? x : (
    (x == top || y == top) ? top : published))
  }

  func frame(x: T, y: T) returns (res: T) {
    (x == published && y == unpublished) ? published : (
    (x == published && y == published) ? x :
    ((x == unpublished && y == unpublished) ? unpublished : top))
  }

  func valid(x: T) returns (res: Bool) {
    (x != top)
  }

  func fpuAllowed(x: T, y: T) returns (res: Bool) {
    (x == unpublished && y == unpublished) || (y == published)
  }
}

module PublishedA = Auth[Published]
module ExclU = Excl[Unit]

field value: Int
field initial_value: Int
field flag: Bool
field value_read: Bool
field value_published: PublishedA
field crossed_pending: ExclU
field crossed_gone: ExclU

pred accepted(r: Ref, p: Proph, v: Int, tok: AtomicToken<coinflip>) {
  true
}
pred done(r: Ref, p: Proph, v: Int, tok: AtomicToken<coinflip>) {
  exists res: Int, winn: Bool ::
  auCommit<coinflip>(tok, (r), (res, winn)) &&
    (winn ? (res == (v * v) + 1) : (res == (-1 * (v * v)) - 1))
}
pred gone(r: Ref, p: Proph, v: Int, tok: AtomicToken<coinflip>) {
  own(r, crossed_gone, ExclU.excl(Unit.unit))
}

val helper_accepted: Int = 0;
val helper_done: Int = 1;
val helper_gone: Int = 2;

inv helper_protocol(r: Ref, p: Proph, v: Int, tok: AtomicToken<coinflip>) {
  (exists i: Int, pub: Published :: (0 <= i < 3) &&
   own(r, value_published, PublishedA.auth_frag(pub, pub)) &&
   ((i == helper_accepted) ==> (pub == Published.unpublished) && accepted(r, p, v, tok)) &&
   ((i == helper_done) ==> (pub == Published.published) && done(r, p, v, tok)) &&
   ((i == helper_gone) ==> (pub == Published.published) && gone(r, p, v, tok)))
}

pred is_helper_protocol(r: Ref) {
  exists p: Proph, v: Int, tok: AtomicToken<coinflip> ::
  own(r, initial_value, v, 0.25) && helper_protocol(r, p, v, tok)
}

inv coinflip_protocol(r: Ref) {
  exists helper_protocol_ready: Bool ::
  helper_protocol_ready ?
    (own(r, crossed_pending, ExclU.excl(Unit.unit)) &&
     is_helper_protocol(r)) :
   true
}

pred is_coinflip(r: Ref) {
  own(r, value_published, PublishedA.auth_frag(Published.unpublished, Published.unpublished)) &&
  coinflip_protocol(r)
}

proc helper(r: Ref, p: Proph, which: Bool, implicit ghost v: Int, implicit ghost tok: AtomicToken<coinflip>)
     requires helper_protocol(r, p, v, tok)
     ensures helper_protocol(r, p, v, tok) &&
             own(r, value_published, PublishedA.frag(Published.published)) {
             assume false;
}

proc coinflip_inner(r: Ref, p: Proph, implicit ghost v: Int, implicit ghost tok: AtomicToken<coinflip>) returns (res: Int, implicit ghost winn: Bool)
  requires helper_protocol(r, p, v, tok) && own(r, crossed_gone, ExclU.excl(Unit.unit))
  ensures helper_protocol(r, p, v, tok) &&
          auCommit<coinflip>(tok, (r), (res, winn)) &&
          (winn ? (res == (v * v) + 1) : (res == (-1 * (v * v)) - 1)) {
  spawn helper(r, p, true, v, tok);
  helper(r, p, false, v, tok);
  ghost var i: Int; ghost var pub: Published;
  unfold helper_protocol(r, p, v, tok)[i := i, pub := pub];
  {!
    if (i == helper_gone) {
      unfold gone(r, p, v, tok);
      assert false;
    } else {
      unfold done(r, p, v, tok)[res := res, winn := winn];
      fold gone(r, p, v, tok);
    }
  !}
  fold helper_protocol(r, p, v, tok)[i := helper_gone, pub := pub];
}

proc coinflip(r: Ref, implicit ghost v: Int, implicit ghost w: Int) returns (res: Int, implicit ghost winn: Bool)
  requires is_coinflip(r) && own(r, crossed_pending, ExclU.excl(Unit.unit)) && own(r, initial_value, w, 0.5) && (v == w) && own(r, crossed_gone, ExclU.excl(Unit.unit))
  atomic requires own(r, value, v) && own(r, initial_value, w, 0.5) && (v == w)
  atomic ensures winn ? (res == ((v * v) + 1)) : (res == ((-1) * (v * v)) - 1) {
  ghost var phi: AtomicToken<coinflip> := bindAU();
  var proph_winner: Proph;
  var helpers: List[Bool];
  proph_winner, helpers := Proph.new[Bool];
  unfold is_coinflip(r);
  ghost var ready: Bool := false;
  unfold coinflip_protocol(r)[ready := helper_protocol_ready];
  assert !ready;
  fold accepted(r, proph_winner, v, phi);
  fold helper_protocol(r, proph_winner, v, phi)[i := 0];
  fold is_helper_protocol(r)[p := proph_winner, tok := phi];
  fold coinflip_protocol(r)[helper_protocol_ready := ready];
  var read_v: Int := r.initial_value;
  ghost var au_v: Int;
  ghost var au_w: Int;
  res, winn := coinflip_inner(r, proph_winner, v, phi);
}


